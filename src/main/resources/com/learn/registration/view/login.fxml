<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  LOGIN VIEW
  Gate screen — shown before anything else.
  Supports two login modes toggled by a ToggleButton:
    - Admin  : username + password  (admin_users table)
    - User   : email    + password  (users table)
-->
<BorderPane xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.learn.registration.view.LoginViewController"
            prefWidth="420" prefHeight="520"
            stylesheets="@../css/style.css">

    <!-- ── Top bar ── -->
    <top>
        <VBox styleClass="top-bar" alignment="CENTER">
            <Label text="JavaFX Registration" styleClass="page-title"/>
            <Label text="MVC + Security Demo"  styleClass="page-subtitle"/>
        </VBox>
    </top>

    <!-- ── Login card ── -->
    <center>
        <VBox spacing="20" styleClass="login-card" alignment="TOP_CENTER">

            <!-- Role toggle -->
            <HBox alignment="CENTER" spacing="0" styleClass="toggle-bar">
                <ToggleButton fx:id="adminToggle" text="Admin Login"
                              styleClass="toggle-btn-left" selected="true"/>
                <ToggleButton fx:id="userToggle"  text="User Login"
                              styleClass="toggle-btn-right"/>
            </HBox>

            <!-- Username / Email label (changes with mode) -->
            <VBox spacing="6">
                <Label fx:id="usernameLabel" text="Username"
                       styleClass="form-label"/>
                <TextField fx:id="usernameField"
                           promptText="Enter username"
                           styleClass="form-input login-input"/>
            </VBox>

            <!-- Password -->
            <VBox spacing="6">
                <Label text="Password" styleClass="form-label"/>
                <PasswordField fx:id="passwordField"
                               promptText="Enter password"
                               styleClass="form-input login-input"/>
            </VBox>

            <!-- Status message -->
            <Label fx:id="statusLabel" text="" wrapText="true"
                   maxWidth="320" styleClass="status-label"
                   visible="false" managed="false"/>

            <!-- Login button -->
            <Button fx:id="loginBtn" text="Login"
                    onAction="#onLogin"
                    styleClass="btn-primary login-btn"
                    defaultButton="true" maxWidth="Infinity"/>

            <Separator/>

            <!-- Hint -->
            <VBox spacing="4" alignment="CENTER" styleClass="hint-box">
                <Label text="Default admin credentials:" styleClass="hint-title"/>
                <Label text="Username: admin" styleClass="hint-text"/>
                <Label text="Password: admin123" styleClass="hint-text"/>
                <Label text="(Change after first login)" styleClass="hint-warn"/>
            </VBox>

        </VBox>
    </center>

    <!-- ── Footer ── -->
    <bottom>
        <HBox styleClass="bottom-bar" alignment="CENTER" spacing="6">
            <Label text="No account?" styleClass="form-label"/>
            <Button text="Register here" onAction="#onGoToRegister"
                    styleClass="btn-link"/>
        </HBox>
    </bottom>

</BorderPane>
